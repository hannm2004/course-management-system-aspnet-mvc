@model CourseManagement.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

@section Styles {
<style>
    .profile-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 60px 0 40px;
        color: white;
        margin-top: -1px;
    }

    .profile-card {
        background: white;
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 10px 50px rgba(0,0,0,0.08);
        margin-top: -40px;
        position: relative;
        z-index: 1;
    }

    .profile-avatar-large {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 2.5rem;
        font-weight: 800;
        margin: 0 auto 20px;
        box-shadow: 0 8px 20px rgba(102,126,234,0.3);
        border: 4px solid white;
    }

    .form-label-custom {
        font-weight: 700;
        font-size: 0.8rem;
        color: #64748b;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control-custom {
        border: 2px solid #f1f5f9;
        border-radius: 14px;
        padding: 12px 18px;
        font-size: 1rem;
        transition: all 0.3s;
        background: #f8fafc;
    }

    .form-control-custom:focus {
        background: white;
        border-color: #667eea;
        box-shadow: 0 0 0 4px rgba(102,126,234,0.1);
        outline: none;
    }

    .btn-save-profile {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        border-radius: 14px;
        padding: 14px 40px;
        font-weight: 700;
        transition: all 0.3s;
    }

    .btn-save-profile:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(102,126,234,0.4);
        color: white;
    }

    .section-subtitle {
        color: #94a3b8;
        font-size: 0.85rem;
        margin-bottom: 24px;
        padding-bottom: 12px;
        border-bottom: 1px solid #f1f5f9;
    }
</style>
}

<div class="profile-hero">
    <div class="container-xl text-center">
        <h1 class="fw-800 mb-2">Tài khoản của bạn</h1>
        <p class="text-white-50">Quản lý thông tin cá nhân và bảo mật tài khoản</p>
    </div>
</div>

<div class="container-xl py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="profile-card">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success border-0 rounded-4 shadow-sm mb-4 d-flex align-items-center gap-3 p-3">
                        <i class="fas fa-check-circle fa-lg text-success"></i>
                        <div class="fw-600">@TempData["Success"]</div>
                    </div>
                }

                <div class="profile-avatar-large">
                    @(Model.FullName?.FirstOrDefault().ToString().ToUpper() ?? "?")
                </div>
                
                <h4 class="text-center fw-800 mb-4">@Model.FullName</h4>

                <form asp-action="Profile" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row g-4">
                        <!-- Basic Info -->
                        <div class="col-12">
                            <h6 class="section-subtitle">THÔNG TIN CƠ BẢN</h6>
                        </div>
                        
                        <div class="col-md-6">
                            <label asp-for="FullName" class="form-label-custom"></label>
                            <input asp-for="FullName" class="form-control form-control-custom" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label-custom"></label>
                            <input asp-for="Email" class="form-control form-control-custom" readonly style="background:#f1f5f9; cursor:not-allowed;" />
                            <div class="form-text small">Email không thể thay đổi</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label-custom"></label>
                            <input asp-for="PhoneNumber" class="form-control form-control-custom" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Address" class="form-label-custom"></label>
                            <input asp-for="Address" class="form-control form-control-custom" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <!-- Security -->
                        <div class="col-12 mt-5">
                            <h6 class="section-subtitle">BẢO MẬT & ĐỔI MẬT KHẨU</h6>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="NewPassword" class="form-label-custom"></label>
                            <input asp-for="NewPassword" class="form-control form-control-custom" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label-custom"></label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-custom" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="col-12 text-center mt-5">
                            <button type="submit" class="btn btn-save-profile">
                                <i class="fas fa-save me-2"></i>Lưu thông tin hồ sơ
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
