@{
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h1 class="text-danger display-1"><i class="fas fa-lock"></i></h1>
            <h2 class="text-danger mt-3">403 - TỪ CHỐI TRUY CẬP</h2>
            <p class="lead mt-3">Bạn không có quyền truy cập vào trang này.</p>
            <p class="text-muted">Vui lòng đăng nhập với tài khoản có quyền hoặc liên hệ quản trị viên.</p>
            
            <div class="mt-4">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary me-2">Về trang chủ</a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Đăng nhập lại</a>
            </div>
        </div>
    </div>
</div>
