@model CourseManagement.Models.Module
@{
    ViewData["Title"] = "Chỉnh sửa Module";
    var course = ViewBag.Course as CourseManagement.Models.Course;
}

@section Styles {
<style>
    .form-hero {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        padding: 50px 0 30px;
        color: white;
        margin-top: -1px;
    }

    .form-card {
        background: white;
        border-radius: 20px;
        padding: 36px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        margin-top: -30px;
        position: relative;
        z-index: 1;
    }

    .form-label-custom {
        font-weight: 600;
        font-size: 0.85rem;
        color: #555;
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control-custom {
        border: 2px solid #f0f0f0;
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 0.95rem;
        transition: border-color 0.3s;
    }

    .form-control-custom:focus {
        border-color: #f093fb;
        box-shadow: 0 0 0 3px rgba(240,147,251,0.1);
    }

    .btn-submit-custom {
        background: linear-gradient(135deg, #f093fb, #f5576c);
        border: none;
        color: white;
        font-weight: 700;
        padding: 13px 32px;
        border-radius: 12px;
        font-size: 0.95rem;
        transition: all 0.3s;
    }

    .btn-submit-custom:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(240,147,251,0.4);
        color: white;
    }
</style>
}

<div class="form-hero">
    <div class="container-xl">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Courses" asp-action="Details" asp-route-id="@course?.Id" class="text-white-50">@course?.Title</a></li>
                <li class="breadcrumb-item active text-white">Chỉnh sửa Module</li>
            </ol>
        </nav>
        <h1 class="fw-800 mb-0" style="font-size:1.8rem;">
            <i class="fas fa-edit me-2"></i>Chỉnh sửa Module
        </h1>
    </div>
</div>

<div class="container-xl py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="form-card">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CourseId" />

                    <div class="mb-4">
                        <label class="form-label-custom">Tên Module <span class="text-danger">*</span></label>
                        <input asp-for="Title" class="form-control form-control-custom" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-custom">Mô tả</label>
                        <textarea asp-for="Description" class="form-control form-control-custom" rows="3"></textarea>
                    </div>

                    <div class="mb-4">
                        <label class="form-label-custom">Thứ tự <span class="text-danger">*</span></label>
                        <input asp-for="Order" class="form-control form-control-custom" type="number" min="1" />
                        <span asp-validation-for="Order" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-3 justify-content-end">
                        <a asp-controller="Courses" asp-action="Details" asp-route-id="@course?.Id"
                           class="btn btn-outline-secondary px-4 rounded-3">Hủy</a>
                        <button type="submit" class="btn-submit-custom">
                            <i class="fas fa-save me-2"></i>Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
