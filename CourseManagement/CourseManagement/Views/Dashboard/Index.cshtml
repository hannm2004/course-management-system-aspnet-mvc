@{
    ViewData["Title"] = "Bảng điều khiển";
    var isAdmin = User.IsInRole("Admin");
}

<div class="container-xl py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-800 mb-1">
                <i class="fas fa-chart-line me-2 text-primary"></i>Bảng điều khiển
            </h1>
            <p class="text-muted mb-0">@(isAdmin ? "Tổng quan hệ thống" : "Quản lý khóa học của bạn")</p>
        </div>
        <div>
            <a asp-controller="Courses" asp-action="Create" class="btn btn-primary rounded-pill px-4">
                <i class="fas fa-plus me-2"></i>Tạo khóa học mới
            </a>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="opacity-80 small mb-1">Khóa học</div>
                        <h2 class="fw-800 mb-0">@ViewBag.TotalCourses</h2>
                    </div>
                    <div class="fs-1 opacity-20">
                        <i class="fas fa-book"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="opacity-80 small mb-1">Học viên</div>
                        <h2 class="fw-800 mb-0">@ViewBag.TotalStudents</h2>
                    </div>
                    <div class="fs-1 opacity-20">
                        <i class="fas fa-users"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-4 h-100" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="opacity-80 small mb-1">Lượt đăng ký</div>
                        <h2 class="fw-800 mb-0">@ViewBag.TotalEnrollments</h2>
                    </div>
                    <div class="fs-1 opacity-20">
                        <i class="fas fa-user-plus"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Enrollments -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-700 mb-0">Đăng ký gần đây</h5>
                    <i class="fas fa-history text-muted"></i>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="text-muted small">
                                <tr>
                                    <th>Học viên</th>
                                    <th>Khóa học</th>
                                    <th>Ngày đăng ký</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var enrollment in (IEnumerable<CourseManagement.Models.CourseEnrollment>)ViewBag.RecentEnrollments)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center" style="width:32px; height:32px; font-size:0.75rem; font-weight:700; color:#667eea;">
                                                    @(enrollment.User?.FullName?.FirstOrDefault().ToString()?.ToUpper() ?? "?")
                                                </div>
                                                <div>
                                                    <div class="fw-600 small">@enrollment.User?.FullName</div>
                                                    <div class="text-muted" style="font-size:0.7rem;">@enrollment.User?.Email</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="small fw-500">@enrollment.Course?.Title</td>
                                        <td class="small text-muted">@enrollment.EnrollmentDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                                @if (!((IEnumerable<CourseManagement.Models.CourseEnrollment>)ViewBag.RecentEnrollments).Any())
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-4 text-muted small italic">Chưa có đăng ký nào.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Popular Courses -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-700 mb-0">Khóa học phổ biến</h5>
                    <i class="fas fa-fire text-orange"></i>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex flex-column gap-3">
                        @foreach (var course in (IEnumerable<CourseManagement.Models.Course>)ViewBag.PopularCourses)
                        {
                            <div class="d-flex align-items-center gap-3 p-2 rounded-3 hover-bg-light transition">
                                <div class="rounded-3 bg-primary bg-opacity-10 text-primary d-flex align-items-center justify-content-center" style="width:48px; height:48px; flex-shrink:0;">
                                    <i class="fas fa-book"></i>
                                </div>
                                <div class="flex-grow-1 overflow-hidden">
                                    <div class="fw-600 text-truncate small">@course.Title</div>
                                    <div class="text-muted" style="font-size:0.75rem;">@course.CourseEnrollments.Count học viên</div>
                                </div>
                                <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id" class="btn btn-sm btn-light rounded-circle">
                                    <i class="fas fa-chevron-right fa-xs"></i>
                                </a>
                            </div>
                        }
                         @if (!((IEnumerable<CourseManagement.Models.Course>)ViewBag.PopularCourses).Any())
                        {
                            <div class="text-center py-4 text-muted small italic">Chưa có khóa học nào.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-bg-light:hover { background-color: #f8f9fa; }
    .transition { transition: all 0.2s ease; }
    .text-orange { color: #fd7e14; }
</style>
