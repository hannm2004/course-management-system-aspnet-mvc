@model IEnumerable<CourseManagement.Models.CourseEnrollment>
@{
    ViewData["Title"] = "Khóa học của tôi";
}

@section Styles {
<style>
    .enrollments-hero {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 60px 0 40px;
        color: white;
        margin-top: -1px;
    }

    .enrollment-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        border: none;
        height: 100%;
    }

    .enrollment-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.15);
    }

    .enrollment-img {
        width: 100%;
        height: 180px;
        object-fit: cover;
        background: linear-gradient(135deg, #667eea, #764ba2);
    }

    .enrollment-img-placeholder {
        width: 100%;
        height: 180px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: rgba(255,255,255,0.6);
    }

    .enrollment-body {
        padding: 20px;
    }

    .enrollment-category {
        display: inline-block;
        background: rgba(102,126,234,0.1);
        color: #667eea;
        font-size: 0.75rem;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 20px;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .enrollment-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 12px;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .progress-section {
        margin-bottom: 16px;
    }

    .progress-label {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: #6c757d;
        margin-bottom: 6px;
    }

    .progress-label span:last-child {
        font-weight: 700;
        color: #667eea;
    }

    .progress-bar-custom {
        height: 8px;
        border-radius: 10px;
        background: #f0f0f0;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        border-radius: 10px;
        background: linear-gradient(90deg, #667eea, #764ba2);
        transition: width 0.5s ease;
    }

    .progress-fill.completed {
        background: linear-gradient(90deg, #11998e, #38ef7d);
    }

    .enrollment-meta {
        font-size: 0.78rem;
        color: #9a9a9a;
        margin-bottom: 16px;
    }

    .enrollment-meta i {
        width: 14px;
    }

    .badge-completed {
        background: linear-gradient(135deg, #11998e, #38ef7d);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .badge-inprogress {
        background: linear-gradient(135deg, #f093fb, #f5576c);
        color: white;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .btn-learn {
        background: linear-gradient(135deg, #667eea, #764ba2);
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px 20px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.3s ease;
    }

    .btn-learn:hover {
        transform: translateX(3px);
        box-shadow: 0 4px 15px rgba(102,126,234,0.4);
        color: white;
    }

    .btn-unenroll {
        background: transparent;
        color: #dc3545;
        border: 1px solid #dc3545;
        border-radius: 10px;
        padding: 8px 16px;
        font-size: 0.8rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-unenroll:hover {
        background: #dc3545;
        color: white;
    }

    .stats-bar {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
    }

    .stat-item {
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .stat-number {
        font-size: 2rem;
        font-weight: 800;
        line-height: 1;
    }

    .stat-label {
        font-size: 0.8rem;
        opacity: 0.8;
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
    }

    .empty-icon {
        font-size: 4rem;
        color: #dee2e6;
        margin-bottom: 20px;
    }

    .certificate-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: linear-gradient(135deg, #f6d365, #fda085);
        color: white;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
    }
</style>
}

<!-- Hero -->
<div class="enrollments-hero">
    <div class="container-xl">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <h1 class="fw-800 mb-1" style="font-size:2rem;">
                    <i class="fas fa-graduation-cap me-2"></i>Khóa học của tôi
                </h1>
                <p class="mb-0 opacity-80">Tiếp tục hành trình học tập của bạn</p>
            </div>
            <div class="stats-bar">
                <div class="stat-item">
                    <span class="stat-number">@Model.Count()</span>
                    <span class="stat-label">Đã đăng ký</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">@Model.Count(e => e.IsCompleted)</span>
                    <span class="stat-label">Hoàn thành</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">@Model.Count(e => !e.IsCompleted && e.CompletionPercentage > 0)</span>
                    <span class="stat-label">Đang học</span>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-xl py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="fas fa-book-open"></i></div>
            <h3 class="fw-700 mb-2">Bạn chưa đăng ký khóa học nào</h3>
            <p class="text-muted mb-4">Khám phá hàng trăm khóa học chất lượng cao và bắt đầu học ngay hôm nay!</p>
            <a asp-controller="Courses" asp-action="Index" class="btn btn-primary px-5 py-2 rounded-pill fw-600">
                <i class="fas fa-search me-2"></i>Khám phá khóa học
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var enrollment in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="enrollment-card">
                        <div style="position:relative;">
                            @if (!string.IsNullOrEmpty(enrollment.Course?.ImageUrl))
                            {
                                <img src="@enrollment.Course.ImageUrl" alt="@enrollment.Course.Title" class="enrollment-img" />
                            }
                            else
                            {
                                <div class="enrollment-img-placeholder">
                                    <i class="fas fa-book"></i>
                                </div>
                            }
                            @if (enrollment.IsCompleted)
                            {
                                <span class="certificate-badge"><i class="fas fa-trophy me-1"></i>Hoàn thành</span>
                            }
                        </div>

                        <div class="enrollment-body">
                            @if (enrollment.Course?.Category != null)
                            {
                                <span class="enrollment-category">@enrollment.Course.Category.Name</span>
                            }

                            <h5 class="enrollment-title">@enrollment.Course?.Title</h5>

                            <div class="progress-section">
                                <div class="progress-label">
                                    <span>Tiến độ</span>
                                    <span>@enrollment.CompletionPercentage%</span>
                                </div>
                                <div class="progress-bar-custom">
                                    <div class="progress-fill @(enrollment.IsCompleted ? "completed" : "")"
                                         style="width:@enrollment.CompletionPercentage%"></div>
                                </div>
                            </div>

                            <div class="enrollment-meta mb-3">
                                <div><i class="far fa-calendar me-1"></i> Đăng ký: @enrollment.EnrollmentDate.ToString("dd/MM/yyyy")</div>
                                <div class="mt-1">
                                    @{
                                        var totalLessons = enrollment.Course?.Modules?.SelectMany(m => m.Lessons)?.Count() ?? 0;
                                    }
                                    <i class="fas fa-list me-1"></i> @totalLessons bài học
                                    @if (enrollment.IsCompleted)
                                    {
                                        <span class="badge-completed ms-2"><i class="fas fa-check me-1"></i>Đã hoàn thành</span>
                                    }
                                    else if (enrollment.CompletionPercentage > 0)
                                    {
                                        <span class="badge-inprogress ms-2"><i class="fas fa-spinner me-1"></i>Đang học</span>
                                    }
                                </div>
                            </div>

                             <div class="d-flex gap-2 flex-wrap">
                                 <a asp-controller="Enrollments" asp-action="Learn"
                                    asp-route-courseId="@enrollment.CourseId"
                                    class="btn-learn">
                                     <i class="fas fa-play"></i>
                                     @(enrollment.CompletionPercentage > 0 ? "Tiếp tục học" : "Bắt đầu học")
                                 </a>
                                 @if (enrollment.IsCompleted)
                                 {
                                     <a asp-action="Certificate" asp-route-courseId="@enrollment.CourseId" 
                                        target="_blank" class="btn btn-outline-warning rounded-10 px-3 fw-bold" 
                                        style="border-radius:10px; font-size:0.85rem; display:inline-flex; align-items:center; gap:6px;">
                                         <i class="fas fa-medal"></i> Chứng chỉ
                                     </a>
                                 }
                                 <form asp-action="Unenroll" method="post" class="d-inline"
                                       onsubmit="return confirm('Bạn có chắc muốn huỷ đăng ký khóa học này?')">
                                     @Html.AntiForgeryToken()
                                     <input type="hidden" name="courseId" value="@enrollment.CourseId" />
                                     <button type="submit" class="btn-unenroll">
                                         <i class="fas fa-times me-1"></i>Huỷ
                                     </button>
                                 </form>
                             </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
