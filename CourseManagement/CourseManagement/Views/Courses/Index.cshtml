@model IEnumerable<CourseManagement.Models.Course>
@{
    ViewData["Title"] = "Danh sách khóa học";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container-xl">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1><i class="fas fa-book-open me-2" style="color:var(--primary-light)"></i>Khóa học</h1>
                <nav aria-label="breadcrumb" class="mt-1">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="breadcrumb-item active">Khóa học</li>
                    </ol>
                </nav>
            </div>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-action="Create" class="btn-primary-custom">
                    <i class="fas fa-plus"></i> Thêm khóa học
                </a>
            }
        </div>
    </div>
</div>

<div class="container-xl pb-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert-dark alert-success mb-4">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="courses-layout">
        <!-- Sidebar Filter -->
        <aside class="filter-sidebar animate-fade-up">
            <form method="get" id="filterForm">
                <div class="filter-title">
                    <i class="fas fa-sliders-h text-primary-light"></i> Bộ lọc tìm kiếm
                </div>

                <!-- Search -->
                <div class="filter-group">
                    <label class="filter-label">Tìm kiếm</label>
                    <div class="search-bar">
                        <i class="fas fa-search"></i>
                        <input type="text" name="search" value="@ViewBag.Search"
                               class="form-control-dark" placeholder="Tên khóa học..." />
                    </div>
                </div>

                <!-- Categories -->
                <div class="filter-group">
                    <label class="filter-label">Danh mục</label>
                    <div class="d-flex flex-column gap-1">
                        <label class="filter-option">
                            <input type="radio" name="categoryId" value="" checked="@(ViewBag.CategoryId == null)" onchange="this.form.submit()" />
                            Tất cả
                        </label>
                        @foreach (var item in (IEnumerable<SelectListItem>)ViewBag.Categories)
                        {
                            <label class="filter-option">
                                <input type="radio" name="categoryId" value="@item.Value" 
                                       checked="@(item.Value == ViewBag.CategoryId?.ToString())" 
                                       onchange="this.form.submit()" />
                                @item.Text
                            </label>
                        }
                    </div>
                </div>

                <!-- Sort -->
                <div class="filter-group">
                    <label class="filter-label">Sắp xếp</label>
                    <select name="sort" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="newest" selected="@(ViewBag.Sort == "newest")">Mới nhất</option>
                        <option value="name" selected="@(ViewBag.Sort == "name")">Tên A-Z</option>
                        <option value="price_asc" selected="@(ViewBag.Sort == "price_asc")">Giá thấp nhất</option>
                        <option value="price_desc" selected="@(ViewBag.Sort == "price_desc")">Giá cao nhất</option>
                    </select>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn-primary-custom w-100 justify-content-center">
                        Áp dụng
                    </button>
                    @if (!string.IsNullOrEmpty(ViewBag.Search as string) || ViewBag.CategoryId != null)
                    {
                        <a asp-action="Index" class="btn-outline-custom w-100 justify-content-center mt-2" style="font-size:0.8rem;">
                            Xóa bộ lọc
                        </a>
                    }
                </div>
            </form>
        </aside>

        <!-- Main Content -->
        <div class="courses-main">
            <!-- Results Info -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span style="color:var(--text-secondary); font-size:0.875rem;">
                    Tìm thấy <strong style="color:var(--text-primary);">@Model.Count()</strong> khóa học
                </span>
            </div>

            <!-- Course Grid -->
            @if (Model.Any())
            {
                <div class="row g-4">
                    @foreach (var course in Model)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card-dark h-100 animate-fade-up">
                                <div class="card-img-wrap">
                                    @if (!string.IsNullOrEmpty(course.ImageUrl))
                                    {
                                        <img src="@course.ImageUrl" alt="@course.Title" loading="lazy" />
                                    }
                                    else
                                    {
                                        <div class="card-img-placeholder">
                                            <i class="fas fa-book-open"></i>
                                        </div>
                                    }
                                    <div style="position:absolute; top:12px; right:12px;">
                                        <span class="@(course.IsActive ? "badge-active" : "badge-inactive") shadow-sm">
                                            @(course.IsActive ? "Đang mở" : "Tạm dừng")
                                        </span>
                                    </div>
                                </div>
                                <div class="card-body-dark d-flex flex-column">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <span class="badge-category">@course.Category?.Name</span>
                                        @if (course.CourseReviews != null && course.CourseReviews.Any())
                                        {
                                            var avg = course.CourseReviews.Average(r => r.Rating);
                                            <span class="text-warning fw-700" style="font-size:0.85rem;">
                                                <i class="fas fa-star me-1"></i>@avg.ToString("0.0")
                                            </span>
                                        }
                                    </div>
                                    
                                    <h3 class="course-title">@course.Title</h3>
                                    
                                    <div class="mt-2 d-flex align-items-center gap-2" style="font-size:0.8rem; color:var(--text-secondary);">
                                        <div style="width:24px; height:24px; border-radius:50%; background:var(--primary); display:flex; align-items:center; justify-content:center; color:white; font-size:0.6rem; font-weight:800;">
                                            @(course.Instructor?.FullName?.FirstOrDefault().ToString() ?? "?")
                                        </div>
                                        <span>@(course.Instructor?.FullName ?? "Admin")</span>
                                    </div>

                                    <div class="mt-3 mb-3" style="color:var(--text-secondary); font-size:0.8rem; display:flex; gap:15px;">
                                        <span><i class="fas fa-users me-1 opacity-50"></i> @(course.CourseEnrollments?.Count ?? 0)</span>
                                        <span><i class="fas fa-layer-group me-1 opacity-50"></i> @(course.Modules?.Count ?? 0) chương</span>
                                    </div>

                                    <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center"
                                         style="border-color:var(--border-color) !important;">
                                        <span class="course-price @(course.Price == 0 ? "free" : "")">
                                            @(course.Price == 0 ? "Miễn phí" : course.Price.ToString("N0") + " ₫")
                                        </span>
                                        <a asp-action="Details" asp-route-id="@course.Id"
                                           class="btn-primary-custom py-1 px-3" style="font-size:0.8rem;">
                                            Chi tiết
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-search"></i>
                    <h5>Không tìm thấy khóa học nào</h5>
                    <p class="mt-2">Thử thay đổi bộ lọc hoặc từ khóa tìm kiếm.</p>
                    <a asp-action="Index" class="btn-outline-custom mt-2">
                        Xóa tất cả bộ lọc
                    </a>
                </div>
            }
        </div>
    </div>
</div>
