@model CourseManagement.Models.Course
@{
    ViewData["Title"] = "Thêm khóa học mới";
}

<div class="page-header">
    <div class="container-xl">
        <h1><i class="fas fa-plus-circle me-2" style="color:var(--primary-light)"></i>Thêm khóa học mới</h1>
        <nav aria-label="breadcrumb" class="mt-1">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Khóa học</a></li>
                <li class="breadcrumb-item active">Tạo mới</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-xl pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="form-dark">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert-dark alert-danger mb-4"></div>

                    <div class="row g-4">
                        <div class="col-12">
                            <label asp-for="Title" class="form-label-dark">
                                <i class="fas fa-heading me-1"></i> Tiêu đề khóa học <span style="color:var(--danger)">*</span>
                            </label>
                            <input asp-for="Title" class="form-control-dark" placeholder="Nhập tiêu đề khóa học..." />
                            <span asp-validation-for="Title" class="text-field-error"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label-dark">
                                <i class="fas fa-align-left me-1"></i> Mô tả
                            </label>
                            <textarea asp-for="Description" class="form-control-dark" rows="4"
                                      placeholder="Nhập mô tả chi tiết về khóa học..."></textarea>
                            <span asp-validation-for="Description" class="text-field-error"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label-dark">
                                <i class="fas fa-tags me-1"></i> Danh mục <span style="color:var(--danger)">*</span>
                            </label>
                            <select asp-for="CategoryId" asp-items="ViewBag.Categories" class="form-select">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="text-field-error"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Price" class="form-label-dark">
                                <i class="fas fa-tag me-1"></i> Giá (VNĐ) <span style="color:var(--danger)">*</span>
                            </label>
                            <input asp-for="Price" type="number" min="0" step="1000" class="form-control-dark" placeholder="0" />
                            <span asp-validation-for="Price" class="text-field-error"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label-dark">
                                <i class="fas fa-calendar-alt me-1"></i> Ngày bắt đầu <span style="color:var(--danger)">*</span>
                            </label>
                            <input asp-for="StartDate" type="date" class="form-control-dark"
                                   value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="StartDate" class="text-field-error"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label-dark">
                                <i class="fas fa-calendar-check me-1"></i> Ngày kết thúc <span style="color:var(--danger)">*</span>
                            </label>
                            <input asp-for="EndDate" type="date" class="form-control-dark"
                                   value="@DateTime.Today.AddMonths(3).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="EndDate" class="text-field-error"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="ImageUrl" class="form-label-dark">
                                <i class="fas fa-image me-1"></i> URL Hình ảnh
                            </label>
                            <input asp-for="ImageUrl" class="form-control-dark" placeholder="https://..." />
                            <span asp-validation-for="ImageUrl" class="text-field-error"></span>
                        </div>

                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3">
                                <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActiveCheck" style="width:20px;height:20px;" />
                                <label asp-for="IsActive" class="form-label-dark mb-0" for="isActiveCheck">
                                    <i class="fas fa-toggle-on me-1"></i> Kích hoạt khóa học
                                </label>
                            </div>
                        </div>

                        <div class="col-12 pt-2">
                            <div class="d-flex gap-3">
                                <button type="submit" class="btn-primary-custom">
                                    <i class="fas fa-save"></i> Lưu khóa học
                                </button>
                                <a asp-action="Index" class="btn-outline-custom">
                                    <i class="fas fa-arrow-left"></i> Quay lại
                                </a>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
