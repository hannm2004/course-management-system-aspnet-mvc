@model CourseManagement.Models.Course
@{
    ViewData["Title"] = Model.Title;
    int totalLessons = Model.Modules?.Sum(m => m.Lessons?.Count ?? 0) ?? 0;
    int totalModules = Model.Modules?.Count ?? 0;
}

<div class="page-header">
    <div class="container-xl">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
                <h1 style="font-size:1.6rem;">@Model.Title</h1>
                <nav aria-label="breadcrumb" class="mt-1">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="breadcrumb-item"><a asp-action="Index">Khóa học</a></li>
                        <li class="breadcrumb-item active">Chi tiết</li>
                    </ol>
                </nav>
            </div>
            @if (User.Identity.IsAuthenticated)
            {
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-success-custom">
                        <i class="fas fa-pen"></i> Sửa
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn-danger-custom">
                        <i class="fas fa-trash"></i> Xóa
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<div class="container-xl pb-5">
    <div class="row g-4">
        <!-- Main Info -->
        <div class="col-lg-8">
            <!-- Cover image -->
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div style="border-radius:var(--radius-lg); overflow:hidden; height:280px; margin-bottom:28px;">
                    <img src="@Model.ImageUrl" alt="@Model.Title"
                         style="width:100%; height:100%; object-fit:cover;" />
                </div>
            }
            else
            {
                <div style="border-radius:var(--radius-lg); height:200px; background:linear-gradient(135deg,rgba(108,99,255,0.15),rgba(255,101,132,0.1)); display:flex;align-items:center;justify-content:center;margin-bottom:28px;border:1px solid var(--border-color);">
                    <i class="fas fa-book-open" style="font-size:4rem; color:var(--primary-light); opacity:0.5;"></i>
                </div>
            }

            <!-- Description -->
            <div class="form-dark mb-4">
                <h5 style="font-weight:700; margin-bottom:14px; color:var(--text-primary);">
                    <i class="fas fa-info-circle me-2" style="color:var(--primary-light)"></i>Mô tả khóa học
                </h5>
                <p style="color:var(--text-secondary); line-height:1.8;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Chưa có mô tả." : Model.Description)
                </p>
            </div>

            <!-- Modules & Lessons -->
            <div class="form-dark">
                <h5 style="font-weight:700; margin-bottom:20px; color:var(--text-primary);">
                    <i class="fas fa-list me-2" style="color:var(--primary-light)"></i>
                    Nội dung khóa học
                    <span class="badge-category ms-2">@totalModules chương · @totalLessons bài học</span>
                </h5>

                @if (Model.Modules != null && Model.Modules.Any())
                {
                    <div class="accordion-modules">
                        @foreach (var module in Model.Modules.OrderBy(m => m.Order))
                        {
                            <div class="module-item mb-3">
                                <div class="module-header" style="background:var(--bg-surface2); border-radius:10px; padding:14px 18px; border:1px solid var(--border-color);">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <span style="font-weight:700; color:var(--text-primary);">
                                                <i class="fas fa-folder me-2" style="color:var(--primary-light)"></i>
                                                Chương @module.Order: @module.Title
                                            </span>
                                        </div>
                                        <span class="badge-category">@(module.Lessons?.Count ?? 0) bài</span>
                                    </div>
                                </div>
                                @if (module.Lessons != null && module.Lessons.Any())
                                {
                                    <div class="module-lessons mt-2 ps-3">
                                        @foreach (var lesson in module.Lessons.OrderBy(l => l.Id))
                                        {
                                            <div class="lesson-item d-flex align-items-center gap-3"
                                                 style="padding:10px 14px; border-bottom:1px solid var(--border-color);">
                                                <i class="fas fa-play-circle" style="color:var(--primary-light); font-size:0.85rem;"></i>
                                                <span style="color:var(--text-secondary); font-size:0.875rem;">@lesson.Title</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state" style="padding:30px;">
                        <i class="fas fa-layer-group" style="font-size:2rem;"></i>
                        <p class="mt-2" style="font-size:0.875rem;">Chưa có nội dung được thêm vào.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- Price & Enroll Card -->
            <div class="form-dark mb-4" style="position:sticky; top:90px;">
                <div class="text-center mb-4">
                    <div class="course-price @(Model.Price == 0 ? "free" : "")" style="font-size:2rem;">
                        @(Model.Price == 0 ? "Miễn phí" : Model.Price.ToString("N0") + " ₫")
                    </div>
                    <span class="@(Model.IsActive ? "badge-active" : "badge-inactive") mt-2 d-inline-block">
                        @(Model.IsActive ? "Đang mở" : "Tạm dừng")
                    </span>
                </div>

                @if (User.Identity.IsAuthenticated)
                {
                    if (ViewBag.IsEnrolled == true)
                    {
                        <div class="alert-dark alert-success text-center mb-3">
                            <i class="fas fa-check-circle me-2"></i> Bạn đã đăng ký khóa học này
                        </div>
                    }
                    else if (Model.IsActive)
                    {
                        <form asp-controller="Enrollments" asp-action="Enroll" method="post">
                            <input type="hidden" name="courseId" value="@Model.Id" />
                            <button type="submit" class="btn-primary-custom w-100 justify-content-center" style="padding:13px;">
                                <i class="fas fa-user-plus"></i> Đăng ký ngay
                            </button>
                        </form>
                    }
                }
                else
                {
                    <a asp-area="Identity" asp-page="/Account/Login" class="btn-primary-custom w-100 justify-content-center" style="padding:13px;">
                        <i class="fas fa-sign-in-alt"></i> Đăng nhập để đăng ký
                    </a>
                }

                <!-- Course Meta -->
                <div class="mt-4" style="border-top:1px solid var(--border-color); padding-top:20px;">
                    <div class="d-flex justify-content-between mb-3">
                        <span style="color:var(--text-secondary); font-size:0.875rem;"><i class="fas fa-tags me-2"></i>Danh mục</span>
                        <a asp-controller="Categories" asp-action="Details" asp-route-id="@Model.CategoryId"
                           class="badge-category" style="text-decoration:none;">@Model.Category?.Name</a>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span style="color:var(--text-secondary); font-size:0.875rem;"><i class="fas fa-chalkboard-teacher me-2"></i>Giảng viên</span>
                        <span style="color:var(--text-primary); font-size:0.875rem; font-weight:600;">@(Model.Instructor?.FullName ?? Model.Instructor?.UserName ?? "N/A")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span style="color:var(--text-secondary); font-size:0.875rem;"><i class="fas fa-calendar me-2"></i>Bắt đầu</span>
                        <span style="color:var(--text-primary); font-size:0.875rem;">@Model.StartDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span style="color:var(--text-secondary); font-size:0.875rem;"><i class="fas fa-calendar-check me-2"></i>Kết thúc</span>
                        <span style="color:var(--text-primary); font-size:0.875rem;">@Model.EndDate.ToString("dd/MM/yyyy")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span style="color:var(--text-secondary); font-size:0.875rem;"><i class="fas fa-users me-2"></i>Học viên</span>
                        <span style="color:var(--text-primary); font-size:0.875rem; font-weight:600;">@(Model.CourseEnrollments?.Count ?? 0)</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span style="color:var(--text-secondary); font-size:0.875rem;"><i class="fas fa-layer-group me-2"></i>Bài học</span>
                        <span style="color:var(--text-primary); font-size:0.875rem; font-weight:600;">@totalLessons</span>
                    </div>
                </div>
            </div>

            <a asp-action="Index" class="btn-outline-custom w-100 justify-content-center">
                <i class="fas fa-arrow-left"></i> Quay lại danh sách
            </a>
        </div>
    </div>
</div>
