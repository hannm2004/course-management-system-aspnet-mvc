@model CourseManagement.Models.ApplicationUser
@{
    ViewData["Title"] = "Chỉnh sửa quyền";
    var allRoles = ViewBag.AllRoles as List<SelectListItem>;
}

<div class="container-xl py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-800 mb-1">
                        <i class="fas fa-user-shield me-2 text-primary"></i>Phân quyền người dùng
                    </h5>
                    <p class="text-muted small">Cập nhật vai trò cho @Model.FullName</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="mb-4">
                            <label class="form-label fw-600 text-muted small uppercase mb-2">Thông tin tài khoản</label>
                            <div class="p-3 bg-light rounded-3 d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-white d-flex align-items-center justify-content-center" style="width:48px; height:48px; font-weight:800; color:#667eea; border:1px solid #eee;">
                                    @(Model.FullName?.FirstOrDefault().ToString()?.ToUpper() ?? "?")
                                </div>
                                <div>
                                    <div class="fw-700">@Model.FullName</div>
                                    <div class="text-muted small">@Model.Email</div>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-600 text-muted small uppercase mb-2">Chọn vai trò</label>
                            <div class="d-flex flex-column gap-2">
                                @foreach (var role in allRoles)
                                {
                                    <div class="form-check custom-checkbox-card">
                                        <input class="form-check-input" type="checkbox" name="roles" value="@role.Value" id="role_@role.Value" @(role.Selected ? "checked" : "")>
                                        <label class="form-check-label w-100 ps-2" for="role_@role.Value">
                                            <div class="fw-600">@role.Text</div>
                                            <div class="text-muted" style="font-size:0.75rem;">
                                                @if(role.Value == "Admin") { <text>Toàn quyền quản trị hệ thống.</text> }
                                                else if(role.Value == "Employee") { <text>Giảng viên: Có quyền tạo và quản lý khóa học.</text> }
                                                else { <text>Học viên: Đăng ký và tham gia các khóa học.</text> }
                                            </div>
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="d-flex gap-2 pt-2">
                            <button type="submit" class="btn btn-primary rounded-pill px-4 flex-grow-1">
                                <i class="fas fa-save me-2"></i>Lưu thay đổi
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-pill px-4">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-checkbox-card {
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 12px 16px 12px 40px;
        transition: all 0.2s;
        cursor: pointer;
    }
    .custom-checkbox-card:hover {
        background-color: #f8f9ff;
        border-color: #667eea;
    }
    .form-check-input:checked + .form-check-label {
        color: #1a1a2e;
    }
    .form-check-input {
        margin-top: 0.5rem;
    }
    .uppercase { text-transform: uppercase; letter-spacing: 0.5px; }
</style>
