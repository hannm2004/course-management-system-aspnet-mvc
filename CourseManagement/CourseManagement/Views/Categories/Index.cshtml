@model IEnumerable<CourseManagement.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<!-- Page Header -->
<div class="page-header">
    <div class="container-xl">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1><i class="fas fa-tags me-2 text-primary-light"></i>Danh mục khóa học</h1>
                <nav aria-label="breadcrumb" class="mt-1">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="breadcrumb-item active">Danh mục</li>
                    </ol>
                </nav>
            </div>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-action="Create" class="btn-primary-custom">
                    <i class="fas fa-plus"></i> Thêm danh mục
                </a>
            }
        </div>
    </div>
</div>

<div class="container-xl pb-5">

    <!-- Alert messages -->
    @if (TempData["Success"] != null)
    {
        <div class="alert-dark alert-success mb-4">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
        </div>
    }

    <!-- Search + Stats -->
    <div class="d-flex flex-wrap gap-3 justify-content-between align-items-center mb-4">
        <form method="get" class="search-bar" style="max-width:360px; width:100%;">
            <i class="fas fa-search"></i>
            <input type="text" name="search" value="@ViewBag.Search"
                   class="form-control-dark" placeholder="Tìm kiếm danh mục..." />
        </form>
        <span style="color:var(--text-secondary); font-size:0.875rem;">
            Tổng cộng <strong style="color:var(--text-primary);">@Model.Count()</strong> danh mục
        </span>
    </div>

    <!-- Table -->
    @if (Model.Any())
    {
        <div class="table-dark-custom">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Tên danh mục</th>
                        <th>Mô tả</th>
                        <th>Số khóa học</th>
                        <th style="text-align:right;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="color:var(--text-secondary); width:50px;">@item.Id</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   style="color:var(--text-primary); font-weight:600; text-decoration:none;">
                                    @item.Name
                                </a>
                            </td>
                            <td style="color:var(--text-secondary); max-width:320px;">
                                @(string.IsNullOrEmpty(item.Description) ? "—" :
                                    (item.Description.Length > 80 ? item.Description.Substring(0, 80) + "…" : item.Description))
                            </td>
                            <td>
                                <span class="badge-category">
                                    <i class="fas fa-book me-1"></i> @(item.Courses?.Count ?? 0) khóa học
                                </span>
                            </td>
                            <td>
                                <div class="d-flex gap-2 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-outline-custom py-1 px-3" style="font-size:0.8rem;">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (User.Identity.IsAuthenticated)
                                    {
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn-success-custom py-1 px-3" style="font-size:0.8rem;">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn-danger-custom py-1 px-3" style="font-size:0.8rem;">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-tags"></i>
            <h5>Chưa có danh mục nào</h5>
            <p class="mt-2">Hãy tạo danh mục đầu tiên để phân loại khóa học!</p>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-action="Create" class="btn-primary-custom mt-3">
                    <i class="fas fa-plus"></i> Tạo danh mục mới
                </a>
            }
        </div>
    }
</div>

@section Styles {
<style>
    .text-primary-light { color: var(--primary-light) !important; }
</style>
}
