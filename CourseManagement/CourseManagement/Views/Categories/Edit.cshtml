@model CourseManagement.Models.Category
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
}

<div class="page-header">
    <div class="container-xl">
        <h1><i class="fas fa-pen me-2" style="color:var(--primary-light)"></i>Chỉnh sửa danh mục</h1>
        <nav aria-label="breadcrumb" class="mt-1">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                <li class="breadcrumb-item"><a asp-action="Index">Danh mục</a></li>
                <li class="breadcrumb-item active">Chỉnh sửa</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-xl pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="form-dark">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert-dark alert-danger mb-4"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label-dark">
                            <i class="fas fa-tag me-1"></i> Tên danh mục <span style="color:var(--danger)">*</span>
                        </label>
                        <input asp-for="Name" class="form-control-dark" />
                        <span asp-validation-for="Name" class="text-field-error"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label-dark">
                            <i class="fas fa-align-left me-1"></i> Mô tả
                        </label>
                        <textarea asp-for="Description" class="form-control-dark" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-field-error"></span>
                    </div>

                    <div class="d-flex gap-3 pt-2">
                        <button type="submit" class="btn-primary-custom">
                            <i class="fas fa-save"></i> Lưu thay đổi
                        </button>
                        <a asp-action="Index" class="btn-outline-custom">
                            <i class="fas fa-arrow-left"></i> Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
